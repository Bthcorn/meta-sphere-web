# ── Dev (recommended): leave API URL unset so requests use this origin and Vite proxies
# to the Nest server (see vite.config.ts: /api and /socket.io → localhost:3000).
# Start API: `pnpm start:dev` in meta-sphere-api on port 3000.
#
# VITE_API_URL=

# ── Or point REST + socket directly at the API (no proxy):
# VITE_API_URL=http://localhost:3000

# Optional overrides (see docs/REALTIME_SPEC.md in meta-sphere-api):
# VITE_SOCKET_URL=http://localhost:3000
# VITE_API_ORIGIN=http://localhost:3000

# Proxy target when using Vite proxy (default http://localhost:3000)
# VITE_PROXY_TARGET=http://localhost:3000

# generated from backend
# VITE_ROOM_MEETING_A_ID=c8287456-1c3e-4d86-9e33-d6ab13cbb351
# VITE_ROOM_MEETING_B_ID=a84744ab-4722-4e9c-8bdd-75105030a61a
